# Copie para .env e preencha antes de subir em producao.
# Em desenvolvimento, pode deixar APP_ENV=dev e omitir APP_SECRET_KEY.

# OBRIGATORIO em producao: chave aleatoria de 32+ bytes (hex)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=troque-por-uma-chave-aleatoria-de-32-bytes-ou-mais

# Opcional: chave separada para criptografar API keys no SQLite.
# Se omitida, APP_SECRET_KEY sera usada.
# API_SECRET_KEY=outra-chave-aleatoria-com-32-bytes-ou-mais

# "production" ativa cookies https_only e desativa reload automatico
# "dev" ativa uvicorn --reload e desativa cookies https_only
APP_ENV=production

# Em producao, cadastro aberto fica desligado por padrao.
# O primeiro usuario ainda pode ser criado se ALLOW_FIRST_USER=1.
# Para liberar novos usuarios, use um convite ou ligue explicitamente.
# ALLOW_REGISTRATION=0
# ALLOW_FIRST_USER=1
# INVITE_CODE=troque-por-um-convite-forte

# Em production, CSRF ja fica ligado; em dev/test pode ser ligado para auditoria.
# ENFORCE_CSRF=1

# Em producao, o endpoint /projects/{id}/kaggle-debug fica desligado por padrao.
# ENABLE_KAGGLE_DEBUG=1

# Pasta onde ficam banco SQLite e arquivos de trabalho (padrao: ./data)
# DATA_DIR=/mnt/volume/brolls-data

# Porta e host que o uvicorn vai escutar (padroes: 127.0.0.1:8000)
# HOST=0.0.0.0
# PORT=8000
